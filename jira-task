#!/usr/bin/env bash
set -euo pipefail

JIRA_TASK_ZSHRC="${JIRA_TASK_ZSHRC:-$HOME/.zshrc}"

check_dependencies() {
  if ! command -v jq &>/dev/null; then
    echo "jq is required. Install with: brew install jq" >&2
    exit 1
  fi
}

usage() {
  echo "Usage: jira-task --config | ISSUE-KEY" >&2
  exit 1
}

set_zshrc_var() {
  local key="$1"
  local value="$2"
  local new_line="export ${key}=\"${value}\""
  if grep -q "^export ${key}=" "$JIRA_TASK_ZSHRC" 2>/dev/null; then
    local tmpfile
    tmpfile=$(mktemp)
    while IFS= read -r line || [[ -n "$line" ]]; do
      if [[ "$line" == "export ${key}="* ]]; then
        printf '%s\n' "$new_line"
      else
        printf '%s\n' "$line"
      fi
    done < "$JIRA_TASK_ZSHRC" > "$tmpfile"
    mv "$tmpfile" "$JIRA_TASK_ZSHRC"
  else
    printf '%s\n' "$new_line" >> "$JIRA_TASK_ZSHRC"
  fi
}

config() {
  echo "Jira Task to Markdown — Configuration"
  echo "Get your API token at: https://id.atlassian.com/manage-profile/security/api-tokens"
  echo ""
  read -r -p "Jira base URL (e.g. https://yourcompany.atlassian.net): " jira_url
  read -r -p "Jira email: " jira_email
  read -r -s -p "Jira API token: " jira_token
  echo ""
  set_zshrc_var "JIRA_URL" "$jira_url"
  set_zshrc_var "JIRA_EMAIL" "$jira_email"
  set_zshrc_var "JIRA_API_TOKEN" "$jira_token"
  echo ""
  echo "Config saved. Run: source $JIRA_TASK_ZSHRC"
}

fetch_issue() {
  local issue_key="$1"
  if [[ -z "${JIRA_URL:-}" ]] || [[ -z "${JIRA_EMAIL:-}" ]] || [[ -z "${JIRA_API_TOKEN:-}" ]]; then
    echo "Missing config. Run: jira-task --config" >&2
    exit 1
  fi

  local auth
  auth=$(printf '%s:%s' "${JIRA_EMAIL}" "${JIRA_API_TOKEN}" | base64 | tr -d '\n')

  local tmpfile
  tmpfile=$(mktemp)

  local http_code
  http_code=$(curl -s -o "$tmpfile" -w "%{http_code}" \
    -H "Authorization: Basic ${auth}" \
    -H "Accept: application/json" \
    "${JIRA_URL}/rest/api/3/issue/${issue_key}?fields=summary,description,attachment") || {
    echo "curl failed" >&2
    rm -f "$tmpfile"
    exit 1
  }

  local response
  response=$(cat "$tmpfile")
  rm -f "$tmpfile"

  case "$http_code" in
    200) ;;
    401|403)
      echo "Authentication failed. Check your email and API token" >&2
      exit 1 ;;
    404)
      echo "Issue ${issue_key} not found" >&2
      exit 1 ;;
    *)
      echo "API error: HTTP ${http_code}" >&2
      exit 1 ;;
  esac

  local summary
  summary=$(printf '%s' "$response" | jq -r '.fields.summary')

  local description_json
  description_json=$(printf '%s' "$response" | jq -c '.fields.description')

  # Create output directory structure
  local output_dir="${issue_key}"
  local images_dir="${output_dir}/images"
  mkdir -p "$images_dir"

  # Extract image attachments from the API response
  local attachments_json
  attachments_json=$(printf '%s' "$response" | jq -c \
    '[.fields.attachment // [] | .[] | select(.mimeType | startswith("image/")) | {id, filename, content}]')

  # Step A: Download all image attachments by numeric ID using their content URL
  local att_id att_filename att_content
  while IFS=$'\t' read -r att_id att_filename att_content; do
    [[ -z "$att_filename" ]] && continue
    curl -sf \
      -H "Authorization: Basic ${auth}" \
      "$att_content" \
      -o "${images_dir}/${att_filename}" 2>/dev/null || true
  done < <(printf '%s' "$attachments_json" | jq -r '.[] | [.id, .filename, .content] | @tsv' 2>/dev/null || true)

  # Step B: For each media UUID in the ADF description, build a UUID→filename map
  local media_map="{}"
  if [[ "$description_json" != "null" ]] && [[ -n "$description_json" ]]; then
    local uuid
    while IFS= read -r uuid; do
      [[ -z "$uuid" ]] && continue

      # Check if the UUID directly matches a numeric attachment ID
      local matched_filename
      matched_filename=$(printf '%s' "$attachments_json" | \
        jq -r --arg id "$uuid" '.[] | select(.id == $id) | .filename // empty' 2>/dev/null || true)

      if [[ -n "$matched_filename" ]]; then
        media_map=$(printf '%s' "$media_map" | jq --arg k "$uuid" --arg v "$matched_filename" '. + {($k): $v}')
        continue
      fi

      # Try downloading directly by UUID (works on Jira Cloud)
      local hdr_file img_tmpfile img_code
      hdr_file=$(mktemp)
      img_tmpfile=$(mktemp)
      img_code=$(curl -s -L -D "$hdr_file" -o "$img_tmpfile" -w "%{http_code}" \
        -H "Authorization: Basic ${auth}" \
        "${JIRA_URL}/rest/api/3/attachment/content/${uuid}" 2>/dev/null) || img_code="000"

      if [[ "$img_code" == "200" ]]; then
        local fname hdr_line
        hdr_line=$(grep -i "^content-disposition:" "$hdr_file" || echo "")
        if [[ "$hdr_line" =~ [Ff]ilename=\"([^\"]+)\" ]]; then
          fname="${BASH_REMATCH[1]}"
        else
          local ctype ext
          ctype=$(grep -i "^content-type:" "$hdr_file" | head -1 || echo "")
          ctype="${ctype##*:}"; ctype="${ctype%%;*}"; ctype="${ctype// /}"
          case "${ctype,,}" in
            image/png)  ext="png" ;;
            image/jpeg) ext="jpg" ;;
            image/gif)  ext="gif" ;;
            image/webp) ext="webp" ;;
            image/svg*)  ext="svg" ;;
            *)          ext="bin" ;;
          esac
          fname="${uuid}.${ext}"
        fi
        mv "$img_tmpfile" "${images_dir}/${fname}"
        media_map=$(printf '%s' "$media_map" | jq --arg k "$uuid" --arg v "$fname" '. + {($k): $v}')
      else
        rm -f "$img_tmpfile"
      fi
      rm -f "$hdr_file"
    done < <(printf '%s' "$description_json" | jq -r \
      '[.. | objects | select(.type == "media" or .type == "mediaInline") | .attrs.id // empty] | unique | .[]' \
      2>/dev/null || true)
  fi

  local description_md=""
  if [[ "$description_json" != "null" ]] && [[ -n "$description_json" ]]; then
    description_md=$(printf '%s' "$description_json" | jq -r --argjson media_map "$media_map" '
      def adf_to_md:
        if type == "null" then ""
        elif type == "object" then
          if .type == "doc" then
            (.content // [] | map(adf_to_md) | join(""))
          elif .type == "text" then
            ((.marks // []) | map(.type) | contains(["strong"])) as $bold |
            ((.marks // []) | map(.type) | contains(["em"])) as $em |
            ((.marks // []) | map(.type) | contains(["code"])) as $code |
            (.text // "") |
            if $bold then
              (. | gsub("\\s+$"; "")) as $inner |
              (. | ltrimstr($inner)) as $trailing |
              ("**" + $inner + "**" + $trailing)
            elif $em then ("_" + . + "_")
            elif $code then ("`" + . + "`")
            else .
            end
          elif .type == "paragraph" then
            ((.content // [] | map(adf_to_md) | join("")) + "\n\n")
          elif .type == "heading" then
            (("#" * (.attrs.level // 1)) + " " + (.content // [] | map(adf_to_md) | join("")) + "\n\n")
          elif .type == "bulletList" then
            (.content // [] | map(adf_to_md) | join(""))
          elif .type == "orderedList" then
            (.content // [] | to_entries | map(
              ((.key + 1) | tostring) + ". " +
              ((.value.content // [] | map(adf_to_md) | join("")) | gsub("\n\n$"; "")) + "\n"
            ) | join(""))
          elif .type == "listItem" then
            ("- " + ((.content // [] | map(adf_to_md) | join("")) | gsub("\n\n$"; "")) + "\n")
          elif .type == "codeBlock" then
            ("```\n" + (.content // [] | map(adf_to_md) | join("")) + "\n```\n\n")
          elif .type == "hardBreak" then "\n"
          elif .type == "rule" then "---\n\n"
          elif .type == "inlineCard" then (.attrs.url // "")
          elif .type == "mention" then ("@" + (.attrs.displayName // .attrs.id // "unknown"))
          elif .type == "mediaSingle" then
            (.content // [] | map(adf_to_md) | join(""))
          elif .type == "media" then
            ($media_map[.attrs.id // ""] // "") as $fname |
            if $fname != "" then "![" + $fname + "](images/" + $fname + ")\n\n"
            else "" end
          elif .type == "mediaInline" then
            ($media_map[.attrs.id // ""] // "") as $fname |
            if $fname != "" then "![" + $fname + "](images/" + $fname + ")"
            else "" end
          elif .type == "table" then
            .content as $rows |
            if ($rows | length) == 0 then ""
            else
              (($rows[0].content // []) | map(.attrs.colspan // 1) | add // 0) as $ncols |
              def expand_row(ncols):
                "| " + (.content // [] | map(
                  (.attrs.colspan // 1) as $span |
                  adf_to_md as $cell |
                  [$cell] + [range($span - 1) | ""]
                ) | flatten |
                . + [range(ncols - length) | ""] |
                join(" | ")) + " |\n";
              "\n" +
              ($rows[0] | expand_row($ncols)) +
              "| " + ([range($ncols) | "---"] | join(" | ")) + " |\n" +
              ($rows[1:] | map(expand_row($ncols)) | join("")) + "\n"
            end
          elif .type == "tableRow" then
            "| " + (.content // [] | map(adf_to_md) | join(" | ")) + " |\n"
          elif .type == "tableCell" or .type == "tableHeader" then
            (.content // [] | map(adf_to_md) | join("")
              | gsub("\\s+$"; "")
              | gsub("\n"; " ")
              | gsub(" {2,}"; " ")
              | ltrimstr(" ")
              | gsub("\\|"; "\\|"))
          else (.content // [] | map(adf_to_md) | join(""))
          end
        elif type == "array" then
          map(adf_to_md) | join("")
        else ""
        end;
      adf_to_md
    ')
  fi

  local output_file="${output_dir}/${issue_key}.md"
  {
    printf '# %s: %s\n' "$issue_key" "$summary"
    if [[ -n "$description_md" ]]; then
      printf '\n## Description\n\n'
      printf '%s' "$description_md"
    fi
  } > "$output_file"

  echo "Written to ${output_file}"
}

check_dependencies

case "${1:-}" in
  --config) config ;;
  "") usage ;;
  *) fetch_issue "$1" ;;
esac
